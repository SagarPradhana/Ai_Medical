# Server runtime
PORT=5000
NODE_ENV=development

# Security
JWT_SECRET=mynameissagar
TOKEN_EXPIRY=8h

# CORS (comma-separated list for production)
# Example: CORS_ORIGIN=https://your-app.com,https://www.your-app.com
CORS_ORIGIN=http://localhost:5173,https://ai-medical-liart.vercel.app

# MongoDB Atlas
# Example: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DB_NAME=ai_medical_portal

# Bootstrap first admin user (recommended for production)
INIT_ADMIN_EMAIL=
INIT_ADMIN_PASSWORD=
INIT_ADMIN_NAME=Platform Admin
